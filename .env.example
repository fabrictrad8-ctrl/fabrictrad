NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false

# Server-only administrator identity. The normal buyer/seller login recognises this verified email.
ADMIN_EMAIL=fabrictrad8@gmail.com
# Used only by `npm run admin:provision`; never expose these as NEXT_PUBLIC values.
ADMIN_PASSWORD=replace-with-a-unique-password-manager-generated-password
ADMIN_FULL_NAME=FabricTrad Administrator
ADMIN_ROLE=super_admin

OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
ALLOWED_OPEN_AI_MODELS=gpt-4o-mini,gpt-4.1-mini
ALLOWED_ANTHROPIC_MODELS=claude-3-5-haiku-latest,claude-3-7-sonnet-latest
ALLOWED_GEMINI_MODELS=gemini/gemini-2.0-flash,gemini/gemini-2.5-flash
ALLOWED_PERPLEXITY_MODELS=sonar,sonar-pro
AI_CHAT_DAILY_LIMIT=100

# Real AI virtual try-on. OPENAI_API_KEY is kept server-side and must also be set as a
# Cloudflare Worker secret in production. Gemini remains an optional fallback provider.
OPENAI_DRAPE_IMAGE_MODEL=gpt-image-2
OPENAI_DRAPE_IMAGE_SIZE=1024x1536
OPENAI_DRAPE_IMAGE_QUALITY=medium
GEMINI_DRAPE_IMAGE_MODEL=gemini/gemini-2.5-flash-image
GEMINI_DRAPE_IMAGE_SIZE=1024x1536
AI_DRAPE_DAILY_LIMIT=10
AI_DRAPE_DEMO_DAILY_LIMIT=2
AI_DRAPE_FALLBACK_DAILY_LIMIT=3
# Optional independent high-entropy secret used to sign fallback browser quota cookies.
AI_DRAPE_COOKIE_SECRET=
# Comma-separated HTTPS hosts allowed when the server fetches a model or fabric image.
AI_IMAGE_SOURCE_HOSTS=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PLATFORM_COMMISSION_RATE=0.10
PAYMENT_PROCESSING_RATE=0.02

SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_WEBHOOK_TOKEN=
DEFAULT_SHIPMENT_LENGTH_CM=10
DEFAULT_SHIPMENT_BREADTH_CM=10
DEFAULT_SHIPMENT_HEIGHT_CM=10
DEFAULT_SHIPMENT_WEIGHT_KG=0.5

NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_ADSENSE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
