NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false

# Used only by `npm run admin:provision`; never expose these as NEXT_PUBLIC values.
ADMIN_EMAIL=admin@fabrictrad.com
ADMIN_PASSWORD=replace-with-a-unique-password-manager-generated-password
ADMIN_FULL_NAME=FabricTrad Administrator
ADMIN_ROLE=super_admin

OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
ALLOWED_OPEN_AI_MODELS=gpt-4o-mini,gpt-4.1-mini
ALLOWED_ANTHROPIC_MODELS=claude-3-5-haiku-latest,claude-3-7-sonnet-latest
ALLOWED_GEMINI_MODELS=gemini/gemini-2.0-flash,gemini/gemini-2.5-flash
ALLOWED_PERPLEXITY_MODELS=sonar,sonar-pro
AI_CHAT_DAILY_LIMIT=100
AI_DRAPE_DAILY_LIMIT=10
AI_IMAGE_SOURCE_HOSTS=

