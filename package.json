{
  "name": "fabrictrad",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <25"
  },
  "rocketCritical": {
    "dependencies": [
      "next",
      "react",
      "react-dom",
      "@dhiwise/component-tagger",
      "@tailwindcss/typography",
      "recharts"
    ],
    "devDependencies": [
      "typescript",
      "@types/node",
      "@types/react",
      "@types/react-dom",
      "@typescript-eslint/eslint-plugin",
      "@typescript-eslint/parser",
      "eslint-config-next",
      "tailwindcss",
      "autoprefixer",
      "postcss",
      "eslint",
      "prettier",
      "@netlify/plugin-nextjs"
    ],
    "scripts": [
      "dev",
      "build",
      "start",
      "lint",
      "lint:fix",
      "format",
      "serve",
      "type-check"
    ],
    "warning": "🚨 CRITICAL: DO NOT REMOVE OR MODIFY ABOVE DEPENDENCIES - Required for Next.js 15 TypeScript app functionality"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md,json}\"",
    "serve": "next start -p ${PORT:-3000}",
    "type-check": "tsc --noEmit",
    "check": "npm run type-check && npm run lint && npm run build",
    "build:sites": "opennextjs-cloudflare build && node scripts/patch-opennext-worker.mjs"
  },
  "dependencies": {
    "@dhiwise/component-tagger": "^1.0.15",
    "@heroicons/react": "^2.2.0",
    "@rocketnew/llm-sdk": "^1.1.0",
    "@supabase/ssr": "0.12.3",
    "@supabase/supabase-js": "2.110.7",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "lucide-react": "^1.7.0",
    "next": "15.5.18",
    "razorpay": "^2.9.4",
    "react": "19.0.3",
    "react-dom": "19.0.3",
    "react-hot-toast": "^2.6.0",
    "recharts": "^2.15.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9.0.0",
    "@netlify/plugin-nextjs": "^5.11.1",
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/node": "^20",
    "@types/react": "19.0.3",
    "@types/react-dom": "19.0.3",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "autoprefixer": "10.4.2",
    "eslint": "^9",
    "eslint-config-next": "^15.2.4",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "postcss": "^8.5.19",
    "prettier": "^3.5.3",
    "tailwindcss": "3.4.6",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.19",
    "esbuild": "^0.28.1"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "unrs-resolver@1.11.1": true,
    "esbuild@0.28.1": true
  }
}
